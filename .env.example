# ActionPhase Environment Configuration
# Copy this file to .env and modify values as needed for local development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Primary database connection (required)
# For local Docker development:
DATABASE_URL="postgres://postgres:example@localhost:5432/actionphase?sslmode=disable"

# Test database connection (optional - will default to DATABASE_URL + "_test")
# For running integration tests locally:
TEST_DATABASE_URL="postgres://postgres:example@localhost:5432/actionphase_test?sslmode=disable"

# =============================================================================
# Database Connection Pool Tuning
# =============================================================================
# The application automatically sets environment-appropriate defaults:
#   - Development: MaxConns=5, MinConns=1 (single developer)
#   - Staging: MaxConns=10, MinConns=3 (light testing, 1 server)
#   - Production: MaxConns=35, MinConns=9 (assumes 2 app servers)
#
# Production Sizing Formula:
#   connections_per_server = (postgres_max_connections * 0.8) / num_app_servers
#
#   Example: PostgreSQL max_connections=100, 2 app servers
#   → (100 * 0.8) / 2 = 40 connections per server
#   → Set DATABASE_MAX_CONNECTIONS=35 (conservative, leaves headroom)
#
# Only override these if you have specific requirements:

# Maximum connections per application server (optional)
# Default: environment-specific (5/10/35 for dev/staging/prod)
# DATABASE_MAX_CONNECTIONS=35

# Minimum warm connections to maintain (optional)
# Reduces latency on cold starts (recommended: ~25% of MaxConnections)
# Default: environment-specific (1/3/9 for dev/staging/prod)
# DATABASE_MIN_CONNECTIONS=9

# Maximum lifetime of a connection before recycling (optional)
# Prevents stale connections and handles database-side limits
# Default: 1h
# DATABASE_MAX_CONN_LIFETIME=1h

# How long idle connections stay in pool before closing (optional)
# Balances resource usage with connection reuse
# Default: 30m
# DATABASE_MAX_IDLE_TIME=30m

# How often to check connection health (optional)
# Detects and removes dead connections from pool
# Default: 1m
# DATABASE_HEALTH_CHECK_PERIOD=1m

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# JWT signing secret (required - use a strong, random key for production)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-signing-key-change-this-in-production"

# JWT token expiration times (optional)
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h  # 7 days
JWT_ALGORITHM=HS256

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# HTTP server settings (optional)
PORT=3000
HOST=0.0.0.0

# Server timeouts (optional)
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Database migrations (true/false)
RUN_MIGRATIONS=true

# CORS settings (optional)
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL for email links (verification, password reset, etc.)
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# Comment threading depth limits (optional)
# Maximum nesting level for threaded comments in main view (0-10)
# Comments are shown at depths 0 through (MAX_DEPTH - 1), with Reply buttons on all
# "Continue thread" button appears on comments at (MAX_DEPTH - 1) that have deeper replies
# Default: 5 (shows depths 0-4 with Reply buttons, "Continue thread" at depth 4)
COMMENT_MAX_DEPTH=5

# Mobile threading depth limit (0-10)
# On mobile, show "Continue thread" earlier to save screen space
# Default: 4 (shows depths 0-2 with Reply buttons, "Continue thread" at depth 2)
VITE_COMMENT_MAX_DEPTH_MOBILE=4

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email provider (resend, mailhog, smtp)
EMAIL_PROVIDER=mailhog

# Email sender information
EMAIL_FROM=noreply@action-phase.com
EMAIL_FROM_NAME=ActionPhase

# Resend (production email provider - https://resend.com)
# Free tier: 3,000 emails/month, no credit card required
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=

# MailHog (local development SMTP catcher)
# Docker: docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
# Web UI: http://localhost:8025
MAILHOG_HOST=localhost
MAILHOG_PORT=1025

# Generic SMTP settings (if using EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# =============================================================================
# BOT PREVENTION & CAPTCHA
# =============================================================================

# hCaptcha configuration (https://www.hcaptcha.com)
# Free tier: Unlimited requests
# Get your keys from: https://dashboard.hcaptcha.com/sites
# NOTE: Frontend needs VITE_ prefixed variables (these are bundled into the build)
HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000
HCAPTCHA_ENABLED=false  # Set to true in production

# Frontend environment variables (VITE_ prefix required for client-side access)
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
VITE_HCAPTCHA_ENABLED=false  # Set to true in production

# Bot prevention settings
# REQUIRE_EMAIL_VERIFICATION controls whether users must verify their email before:
#   - Creating games
#   - Applying to games
#   - Creating characters
#   - Posting in common room
#   - Commenting on posts
# Set to "false" for local development (default: "true" in production)
# Note: Test fixtures pre-verify all test users for easier testing
REQUIRE_EMAIL_VERIFICATION=false
MAX_REGISTRATIONS_PER_IP_PER_DAY=5
BLOCK_DISPOSABLE_EMAILS=true
PASSWORD_MIN_LENGTH=8

# When true, new accounts are placed in a pending_approval state and cannot login
# until an admin approves them via the admin panel. Use this if ban evasion is a concern.
REQUIRE_REGISTRATION_APPROVAL=false

# Token expiry for password reset and email verification
TOKEN_EXPIRY_HOURS=1

# =============================================================================
# DISCORD INTEGRATION
# =============================================================================

# Discord bot token for sending DMs to users who link their Discord account.
# When empty, a mock client is used (logs DMs to stdout for local development).
# Get your bot token from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Discord OAuth2 application credentials for account linking.
# Create a new application at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# The URL Discord will redirect to after authorization.
# Must match exactly what you register in the Discord Developer Portal.
DISCORD_REDIRECT_URL=http://localhost:3000/api/v1/auth/discord/callback

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Storage backend ("local" for dev/staging, "s3" for production)
STORAGE_BACKEND=local

# Local filesystem storage (development/staging)
# Files stored at: {STORAGE_LOCAL_PATH}/{path}
# Served at: {STORAGE_PUBLIC_URL}/{path}
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_URL=http://localhost:3000/uploads

# S3 storage (production)
# Create an S3 bucket for avatar storage with public-read permissions
# The bucket is created automatically by Terraform (see terraform/main.tf)
#
# IMPORTANT: When using S3 backend, comment out STORAGE_PUBLIC_URL above
# to auto-generate S3 URLs: https://{bucket}.s3.{region}.amazonaws.com/{path}
# Or set it to your CDN URL if using CloudFront
STORAGE_S3_BUCKET=actionphase-avatars
STORAGE_S3_REGION=us-east-1

# Optional: For S3-compatible services (DigitalOcean Spaces, MinIO, etc.)
# Leave empty for AWS S3
# STORAGE_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Skip database tests (useful for CI or when DB is not available)
# Set to "true" to run only mock-based tests
SKIP_DB_TESTS=false

# Test configuration
TEST_PARALLEL=false
TEST_CLEANUP=true
TEST_LOG_LEVEL=warn

# =============================================================================
# PRODUCTION DEPLOYMENT
# =============================================================================

# Production domain (required for SSL setup)
DOMAIN=action-phase.com

# Admin email for Let's Encrypt SSL certificates
ADMIN_EMAIL=admin@actio-nphase.com

# Slack webhook for monitoring alerts (optional)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# AWS Configuration for backups (required for production)
AWS_REGION=us-east-1
S3_BACKUP_BUCKET=actionphase-backups

# AWS credentials (use IAM role in EC2, or set these for local testing)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# DOCKER COMPOSE INTEGRATION
# =============================================================================
# The above DATABASE_URL settings work with the default docker-compose.yml
# If you modify docker-compose.yml, update these accordingly:
#
# Default docker-compose database:
# - Host: localhost (from host perspective)
# - Port: 5432 (mapped from container)
# - User: postgres (default)
# - Password: example (set in docker-compose.yml)
# - Database: actionphase (you'll need to create this)
#
# To set up the database:
# 1. Start Docker database: just db_up
# 2. Create main database: createdb -h localhost -U postgres actionphase
# 3. Create test database: createdb -h localhost -U postgres actionphase_test
# 4. Run migrations: just migrate
