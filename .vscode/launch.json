{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}"
        },
        {
            // Attach to the Delve server running in the backend dev container.
            // Start the stack first (`just up`), then run this config. Set
            // breakpoints normally — Air rebuilds restart Delve, so if a rebuild
            // detaches the session, just re-run this config.
            "name": "Attach to backend (Docker/Delve)",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "host": "127.0.0.1",
            "port": 2345,
            // Map the container's /app to the local backend source so breakpoints
            // resolve to the right files.
            "remotePath": "/app",
            "cwd": "${workspaceFolder}/backend"
        }
    ]
}