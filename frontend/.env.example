# Frontend Environment Variables
# Copy this file to .env.local for local development
# Vite requires all environment variables to be prefixed with VITE_

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL (proxy handled by Vite in development)
# Development: Uses Vite proxy (see vite.config.ts)
# Production: Set to your backend URL
VITE_API_URL=http://localhost:3000

# =============================================================================
# Comment Threading Configuration
# =============================================================================

# Comment threading depth limits
# Controls how many nesting levels are visible in comment threads
# Comments are shown at depths 0 through (MAX_DEPTH - 1) with Reply buttons
# "Continue thread" button appears on comments at (MAX_DEPTH - 1) that have deeper replies

# Desktop comment threading depth limit
# Default: 5 (shows depths 0-4, "Continue thread" at depth 4)
# Range: 1-10
VITE_COMMENT_MAX_DEPTH=5

# Mobile comment threading depth limit
# Lower than desktop to save screen space
# Default: 3 (shows depths 0-2, "Continue thread" at depth 2)
# Range: 1-10
VITE_COMMENT_MAX_DEPTH_MOBILE=3

# =============================================================================
# Feature Flags (Optional)
# =============================================================================

# Enable debug logging in development
# VITE_DEBUG=true

# =============================================================================
# Analytics (Optional)
# =============================================================================

# Google Analytics ID
# VITE_GA_ID=G-XXXXXXXXXX

# =============================================================================
# Observability (Grafana Faro RUM)
# =============================================================================

# Current environment label — used to distinguish dev vs prod data in Grafana.
VITE_ENVIRONMENT=development

# Grafana Faro Real User Monitoring
# Set VITE_FARO_ENABLED=true and provide the collector URL to ship RUM data.
# Find the URL in Grafana Cloud portal → Frontend Observability → your app → Configure.
VITE_FARO_ENABLED=false
VITE_FARO_URL=
VITE_FARO_APP_NAME=actionphase

# Grafana Faro source map upload (build-time only, not VITE_ prefixed).
# Enables deobfuscated stack traces in the Frontend Observability UI.
# Find all values in Grafana Cloud → Frontend Observability → your app → Settings → Source Maps.
# Leave blank locally — only set in CI/production builds.
GRAFANA_FARO_API_KEY=
GRAFANA_FARO_SOURCEMAP_ENDPOINT=
GRAFANA_FARO_APP_ID=
GRAFANA_FARO_STACK_ID=
